@model IEnumerable<Vue.Models.Guestbook>

@{
    ViewData["Title"] = "我的小留言板";
}

<h2>留言板測試</h2>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="form-group">
                <label>你的大名：</label>
                <input name="userName" class="form-control" required />
            </div>
            <div class="form-group">
                <label>想說的話：</label>
                <textarea name="content" class="form-control" rows="3" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary mt-2">送出留言</button>
        </form>
    </div>
</div>

<hr />

<h3>大家說了什麼：</h3>
@foreach (var item in Model)
{
    <div class="border p-3 mb-2 bg-light">
        <strong>@item.UserName</strong> <small class="text-muted">(@item.CreatedAt.ToString("yyyy-MM-dd HH:mm"))</small>
        <p class="mt-2">@item.Content</p>
    </div>
}