@{
    ViewData["Title"] = "Vue 修正版";
}

<div id="app">
    <div class="card p-4 text-center">
        <h1>{{ title }}</h1>
        <h2 class="display-1">{{ count }}</h2>

        <div class="mt-3">
            <button class="btn btn-danger" @@click="minus">- 減少</button>
            <button class="btn btn-success" @@click="plus">+ 增加</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>

    <script>
        const { createApp, ref } = Vue;

        createApp({
            setup() {
                const count = ref(100);
                const title = ref("Vue 修正版"); // 補上 title 變數，不然 <h1> 會空白

                // 增加邏輯
                const plus = () => {
                    count.value++;
                };

                // 減少邏輯 (補上這段)
                const minus = () => {
                    // 如果你不想讓數字變成負數，可以加個判斷
                    if (count.value > 0) {
                        count.value--;
                    }
                };

                // 記得把 minus 也丟出去給 HTML 用
                return {
                    count,
                    title,
                    plus,
                    minus
                };
            }
        }).mount('#app');
    </script>
}